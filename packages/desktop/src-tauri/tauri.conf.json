{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeuCofri",
  "version": "2.0.0",
  "identifier": "com.yannb.meucofri",
  "build": {
    "devUrl": "http://127.0.0.1:43173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeuCofri",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "msi",
    "homepage": "https://github.com/yanndrade/finances-app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "bin"
    ],
    "windows": {
      "wix": {
        "bannerPath": "installer-assets/wix-banner.bmp",
        "dialogImagePath": "installer-assets/wix-dialog.bmp",
        "fragmentPaths": [
          "installer-assets/wix-cleanup.wxs"
        ],
        "componentRefs": [
          "CleanupAppData"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yanndrade/finances-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxNEExNEVENjgwM0M0NzkKUldSNXhBTm83UlJLa1dyQ0RJYzZiS3pVdndqVTlqZGpCM1VDbkxKZDN3ZG1HOCtZQk1TZDh5NkUK"
    }
  }
}
