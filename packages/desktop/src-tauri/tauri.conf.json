{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finances App",
  "version": "0.1.0",
  "identifier": "com.yannb.finances",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Finances App",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "bin"
    ]
  }
}
