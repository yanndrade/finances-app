<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="TARGETDIR">
      <Component Id="CleanupAppData" Guid="*">
        <RegistryValue
          Root="HKCU"
          Key="Software\MeuCofri"
          Name="InstallerCleanup"
          Type="integer"
          Value="1"
          KeyPath="yes"
        />
        <RemoveRegistryValue
          Root="HKCU"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
          Name="MeuCofri"
        />
        <RemoveRegistryValue
          Root="HKCU"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
          Name="meucofri-desktop"
        />
        <RemoveRegistryValue
          Root="HKCU"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run"
          Name="MeuCofri"
        />
        <RemoveRegistryValue
          Root="HKCU"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run"
          Name="meucofri-desktop"
        />
        <RemoveRegistryKey Root="HKCU" Key="Software\MeuCofri" Action="removeOnUninstall" />
      </Component>
    </DirectoryRef>

    <Property Id="MEUCOFRI_CLEANUP_CMD" Value="[SystemFolder]cmd.exe" />
    <CustomAction
      Id="CleanupAppDataDirectories"
      Property="MEUCOFRI_CLEANUP_CMD"
      ExeCommand='/C rmdir /S /Q "%LOCALAPPDATA%\com.yannb.meucofri" &amp; rmdir /S /Q "%APPDATA%\com.yannb.meucofri" &amp; rmdir /S /Q "%LOCALAPPDATA%\MeuCofri" &amp; rmdir /S /Q "%APPDATA%\MeuCofri"'
      Execute="deferred"
      Impersonate="yes"
      Return="ignore"
    />

    <InstallExecuteSequence>
      <Custom Action="CleanupAppDataDirectories" After="RemoveFiles">REMOVE="ALL"</Custom>
    </InstallExecuteSequence>
  </Fragment>
</Wix>
