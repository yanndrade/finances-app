root = true

[*.{md,txt}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.ps1]
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,rs,py,json,yml,yaml}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
